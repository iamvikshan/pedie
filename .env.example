# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Sheets
# Generate and write directly to .env:
# Linux/macOS:   printf 'GOOGLE_SHEETS_CREDENTIALS_BASE64="' >> .env && base64 -w 0 service-account.json >> .env && printf '"\n' >> .env
# Windows (PowerShell): [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("service-account.json")) | ForEach-Object { "GOOGLE_SHEETS_CREDENTIALS_BASE64=`"$_`"" } | Add-Content .env
GOOGLE_SHEETS_CREDENTIALS_BASE64=base64-encoded-service-account-json
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_SHEET_NAME=Inventory

# M-Pesa Daraja
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=
DARAJA_ENV=sandbox

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Sync API Key
SYNC_API_KEY=your-secret-sync-key

# Deployment
CLOUDFLARE_TUNNEL_TOKEN=
