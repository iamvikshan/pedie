# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Sheets
# Generate and write directly to .env:
# Linux:         printf 'GCP_SERVICE_ACC="' >> .env && base64 -w 0 service-account.json | tr -d '\n' >> .env && printf '"\n' >> .env
# macOS:         printf 'GCP_SERVICE_ACC="' >> .env && base64 -i service-account.json | tr -d '\n' >> .env && printf '"\n' >> .env
# Windows (PowerShell): [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("service-account.json")) | ForEach-Object { "GCP_SERVICE_ACC=`"$_`"" } | Add-Content .env
GCP_SERVICE_ACC=base64-encoded-service-account-json
GS_SPREADSHEET_ID=your-spreadsheet-id
# Sheet tab name is configured in src/config/index.ts (SHEETS_TAB_NAME)

# M-Pesa Daraja
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=
DARAJA_ENV=sandbox

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Sync API Key
SYNC_API_KEY=your-secret-sync-key

# Deployment
CF_TUNNEL=

# Revalidation
REVALIDATION_SECRET=

# Gmail (Email)
GCP_CLIENT_ID=
GCP_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
