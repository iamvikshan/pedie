{
  "name": "pedie-store",
  "version": "1.2.2",
  "private": true,
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "f": "(git diff --name-only --diff-filter=ACMR HEAD && git ls-files --others --exclude-standard) | xargs bunx prettier --write --ignore-unknown",
    "f:all": "prettier --write .",
    "f:check": "prettier --check .",
    "lint:fix": "eslint . --fix",
    "check": "eslint . && tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf .next",
    "seed": "bun scripts/seed.ts",
    "syncsheets": "bun scripts/sheets.ts",
    "postinstall": "touch .env.local && (grep -q NEXT_TELEMETRY_DISABLED .env.local || echo 'NEXT_TELEMETRY_DISABLED=1' >> .env.local) && (grep -q REACT_EDITOR .env.local || echo 'REACT_EDITOR=code' >> .env.local)",
    "prepare": "husky",
    "upd": "bun update --latest && bun i && bun f"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "sanitize-html": "^2.17.3",
    "typescript": "^6.0.3",
    "use-debounce": "^10.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@happy-dom/global-registrator": "^20.9.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.4",
    "typescript-eslint": "8.59.1"
  },
  "overrides": {
    "typescript-eslint": "8.59.1"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
