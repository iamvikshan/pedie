{
  "name": "pedie-store",
  "version": "1.1.0",
  "private": true,
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "f": "prettier --write .",
    "f:check": "prettier --check .",
    "check": "bun lint && tsc --noEmit",
    "test": "bun test",
    "seed": "bun scripts/seed.ts",
    "crawl": "bun scripts/crawlers/index.ts",
    "prepare": "husky",
    "postinstall": "touch .env.local && (grep -q NEXT_TELEMETRY_DISABLED .env.local || echo 'NEXT_TELEMETRY_DISABLED=1' >> .env.local) && (grep -q REACT_EDITOR .env.local || echo 'REACT_EDITOR=code' >> .env.local)"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/speed-insights": "^1.3.1",
    "cheerio": "^1.2.0",
    "framer-motion": "^12.34.5",
    "googleapis": "^171.4.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "recharts": "^3.7.0",
    "use-debounce": "^10.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "conventional-changelog-conventionalcommits": "^9.2.0",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
